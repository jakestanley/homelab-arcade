# Absolute interpreter used by scripts/up.sh.
ARCADE_PYTHON=/srv/arcade/.venv/bin/python3

# Optional override when the repo checkout lives somewhere other than /srv/arcade.
ARCADE_REPO_ROOT=/srv/arcade

# Optional host-managed config file. Leave unset to use /srv/arcade/config.yaml.
HOMELAB_ARCADE_CONFIG_PATH=/etc/arcade/config.yaml

# homelab-infra owns ingress and the externally assigned portal port.
PORTAL_PORT=20032

# Internal UI ports used by the supervisor-managed child services.
WEB_PORT=5000
DUMMY_PORT=5001
SANDSTORM_WEB_PORT=5002
