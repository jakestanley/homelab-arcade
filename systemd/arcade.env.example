# Optional host-managed config file. Strongly recommended for packaged installs.
HOMELAB_ARCADE_CONFIG_PATH=/etc/arcade/config.yaml

# Optional strict mode. When set to 1, startup fails if HOMELAB_ARCADE_CONFIG_PATH
# points to a missing or unreadable file.
HOMELAB_ARCADE_CONFIG_REQUIRED=0

# homelab-infra or the local host decides the externally assigned portal port.
# The portal still defaults to 80 when this is unset.
PORTAL_PORT=20032

# Internal UI ports used by the supervisor-managed child services.
WEB_PORT=5000
DUMMY_PORT=5001
SANDSTORM_WEB_PORT=5002

# Optional CS2 runtime wrapper. This wraps only the CS2 child process launch
# (for example: steam-run); it does not wrap the supervisor service process.
CS2_EXEC_WRAPPER=
