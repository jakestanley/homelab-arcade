# Optional host-managed config file. Strongly recommended for packaged installs.
HOMELAB_ARCADE_CONFIG_PATH=/etc/arcade/config.yaml

# homelab-infra or the local host decides the externally assigned portal port.
# The portal still defaults to 80 when this is unset.
PORTAL_PORT=20032

# Internal UI ports used by the supervisor-managed child services.
WEB_PORT=5000
DUMMY_PORT=5001
SANDSTORM_WEB_PORT=5002
